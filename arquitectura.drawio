        <mxCell id="pipeline" value="&lt;b&gt;Flujo de Aprendizaje:&lt;/b&gt; Usuario selecciona archivos → POST /api/archivos/aprender → Backend marca EnProcesamiento → POST /train al Trainer → Extrae texto → Enriquece via LLM → Chunks → Embeddings → ChromaDB → Callback PUT /procesado → Procesado=true" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=#666666;fillColor=#f5f5f5;fontColor=#333333;fontSize=11;rounded=1;arcSize=10;" vertex="1" parent="1">
